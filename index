const TIERS = [
  { name:'Seedling',    icon:'🌱', min:0,     max:9,    desc:'Just getting started — every wish counts!',        color:'#00FFB3' },
  { name:'Spark',       icon:'⚡', min:10,    max:49,   desc:'You\'ve ignited something. Keep it burning!',      color:'#FFE566' },
