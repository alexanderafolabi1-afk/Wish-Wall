}
.sp-card:hover{border-color:var(--blue);box-shadow:var(--glow-blue);transform:translateY(-5px);}
.sp-wish-txt{font-family:var(--fn-note);font-size:1.08rem;color:#fff;margin-bottom:16px;line-height:1.55;}
.sp-cost{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.sp-cost-est{font-size:11px;color:rgba(255,255,255,.45);}
.sp-cost-amt{font-family:var(--fn-display);font-size:1.3rem;color:var(--green);}
.sp-btn{
  width:100%;padding:12px;border-radius:50px;border:none;
  background:linear-gradient(135deg,var(--blue),var(--purple));
  color:#fff;font-family:var(--fn-display);font-size:16px;cursor:pointer;
  transition:all .2s;
}
.sp-btn:hover{transform:scale(1.03);box-shadow:var(--glow-blue);}

/* ── Featured Patron Banner ─────────────────────────────────────────────── */
.patron-banner{
  max-width:780px;margin:0 auto 44px;
  border-radius:20px;overflow:hidden;
  border:1.5px solid rgba(180,77,255,.45);
  background:linear-gradient(135deg,rgba(180,77,255,.12) 0%,rgba(0,0,0,.5) 60%,rgba(255,123,44,.08) 100%);
  box-shadow:0 0 40px rgba(180,77,255,.18),0 4px 32px rgba(0,0,0,.35);
  display:flex;flex-direction:column;
}
.patron-top{
  padding:22px 28px 16px;
  display:flex;align-items:flex-start;gap:18px;flex-wrap:wrap;
}
.patron-badge{
  background:linear-gradient(135deg,#B44DFF,#FF7B2C);
  color:#fff;font-family:var(--fn-display);font-size:12px;
  letter-spacing:1.2px;text-transform:uppercase;
  padding:4px 14px;border-radius:50px;white-space:nowrap;
