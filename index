function paintWall(){
  const grid = document.getElementById('wall-grid');
  let src = allWishes;

  if(curFilter === 'granted') src = src.filter(w => w.status === 'granted');
  else if(curFilter === 'live') src = src.filter(w => w.status !== 'granted');

  if(searchQ){
    const q = searchQ.toLowerCase();
    src = src.filter(w => w.wishText.toLowerCase().includes(q));
  }

  if(src.length === 0){
    grid.innerHTML = '<div class="wall-empty">✨ No wishes found. Be the first to pin one! 📌</div>';
    return;
  }
  grid.innerHTML = src.map((w,i) => noteHTML(w,i)).join('');
}

function noteHTML(w, i){
  const color  = w.color || NOTE_COLS[i % NOTE_COLS.length];
  const pinCls = PIN_COLS[i % PIN_COLS.length];
  const rot    = ROTS[i % ROTS.length];
  const delay  = Math.min(i * 0.045, 0.7).toFixed(2);
  const granted = w.status === 'granted';
  let dateStr = 'Recently';
  try{
    const d = w.createdAt?.toDate ? w.createdAt.toDate() : (w.createdAt ? new Date(w.createdAt) : new Date());
    dateStr = d.toLocaleDateString('en-GB',{day:'numeric',month:'short'});
  }catch(_){}

  return `
<div class="note-card ${color}"
     style="--rot:${rot}deg;transform:rotate(${rot}deg);animation-delay:${delay}s"
     data-id="${esc(w.id)}">
  <div class="note-inner">
    <div class="note-pin ${pinCls}"></div>
    <p class="note-text">${esc(w.wishText)}</p>
    <div class="note-footer">
      <span class="note-date">${dateStr}</span>
      ${granted ? `<span class="granted-badge">✅ Granted</span>` : ''}
    </div>
  </div>
</div>`;
}

