/* ============================================================
   SUBMIT WISH → FIREBASE + STRIPE
   ============================================================ */
async function submitWish(){
  const wishTxt = document.getElementById('f-wish').value.trim();
  const name    = document.getElementById('f-name').value.trim();
  const email   = document.getElementById('f-email').value.trim();
  const anon    = document.getElementById('f-anon').checked;
  const btn     = document.getElementById('sub-btn');

  if(!wishTxt)             { shake(document.getElementById('f-wish'));  return alert('✨ Please write your wish!'); }
  if(wishTxt.length > 200) { return alert('Keep your wish under 200 characters!'); }
  if(!email || !email.includes('@')) { shake(document.getElementById('f-email')); return alert('We need a valid email to notify you when your wish is granted 💌'); }
  if(hasProfanity(wishTxt)){ return alert('Please keep the magic family-friendly! 🌟'); }

  btn.disabled    = true;
  btn.textContent = '✨ Saving your wish...';
  storedWishTxt   = wishTxt;

  const wishData = {
    wishText: wishTxt,
    name:     anon ? '' : name,
    email,
    anonymous: anon,
    status:   'pending',
    color:    NOTE_COLS[Math.floor(Math.random() * NOTE_COLS.length)]
  };

  try {
    if(window._firebaseReady && window.saveWish){
      const docRef = await window.saveWish(wishData);
      const wishId = docRef.id;
      // Redirect to Stripe Payment Link with wish ID
      window.location.href = `${STRIPE_PAYMENT_LINK}?client_reference_id=${wishId}&prefilled_email=${encodeURIComponent(email)}`;
    } else {
      // Demo mode — skip payment, show confirmation
      console.log('Demo mode: wish saved locally', wishData);
      btn.disabled = false;
      btn.textContent = '✨ Pin It for £2';
      closeModal();
      showConf(wishTxt);
    }
  } catch(err){
    console.error('Save error:', err);
    btn.disabled = false;
    btn.textContent = '✨ Pin It for £2';
    // Fallback to demo confirmation
    closeModal();
    showConf(wishTxt);
  }
}

function shake(el){
