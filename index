<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
  import {
    getFirestore, collection, addDoc, getDocs, doc, updateDoc,
    onSnapshot, query, where, orderBy, serverTimestamp, getDoc
  } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

  // ⚠️ REPLACE WITH YOUR FIREBASE CONFIG
  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    projectId: "YOUR_PROJECT_ID",
    storageBucket: "YOUR_PROJECT.appspot.com",
    messagingSenderId: "YOUR_SENDER_ID",
    appId: "YOUR_APP_ID"
  };

  try {
    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // Expose globally for the main script block
    window._db = db;
    window._col = {
      wishes: collection(db, 'wishes'),
      donors: collection(db, 'donors'),
      ledger: doc(db, 'meta', 'ledger')
    };
    window._fb = { addDoc, updateDoc, onSnapshot, query, where, orderBy, serverTimestamp, getDoc };

    // Real-time wish listener
    const q = query(window._col.wishes, where('status', '==', 'approved'), orderBy('createdAt', 'desc'));
    onSnapshot(q, snap => {
      const wishes = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      window.renderWishes(wishes);
    });

    // Ledger listener
    onSnapshot(window._col.ledger, snap => {
      if (snap.exists()) window.updateLedger(snap.data());
    });

    // Expose save function
    window.saveWish = async (data) => addDoc(window._col.wishes, { ...data, createdAt: serverTimestamp() });

    window._firebaseReady = true;
    console.log('✨ Firebase connected');
  } catch(e) {
    console.warn('Firebase not configured — running in demo mode:', e.message);
    window._firebaseReady = false;
  }
</script>

