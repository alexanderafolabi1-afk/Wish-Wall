/* ============================================================
   MILESTONE PROGRESS BAR — fully wired
   ============================================================ */
const MILESTONES = [100, 250, 500, 1000, 2500, 5000, 10000];

function updateMilestone(total){
  const next = MILESTONES.find(m => m > total) || MILESTONES[MILESTONES.length - 1] * 2;
  const prev = MILESTONES.slice().reverse().find(m => m <= total) || 0;
  const pct  = Math.min(((total - prev) / (next - prev)) * 100, 100);
  const left = Math.max(next - total, 0);

  const bar   = document.getElementById('ms-bar');
  const badge = document.getElementById('ms-badge');
  const lbl   = document.getElementById('ms-lbl');

  if(bar)   bar.style.width = pct.toFixed(1) + '%';
  if(badge) badge.textContent = `🏆 ${next.toLocaleString()} wishes`;
  if(lbl)   lbl.innerHTML = left > 0
    ? `✨ <strong style="color:var(--yellow)">${left.toLocaleString()}</strong> wishes to the next milestone!`
    : `🎉 Milestone reached! You're magic.`;
}

