async function sponsorWish(id){
  const amtStr = prompt('How much would you like to contribute? (£)\nMinimum £1');
  if(!amtStr) return;
  const amtFloat = parseFloat(amtStr);
  if(isNaN(amtFloat) || amtFloat < 1){ alert('Please enter a valid amount of at least £1.'); return; }
  const amtPence = Math.round(amtFloat * 100);

  try{
    const btn = document.querySelector(`[data-id="${id}"] .sp-btn`) || document.body;
    btn.textContent = '⏳ Connecting to Stripe...';
    btn.disabled = true;

    const res  = await fetch('/.netlify/functions/create-sponsor-session', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ wishId: id, amount: amtPence })
    });
    const data = await res.json();

    if(data.url){ window.location.href = data.url; }
    else{ throw new Error(data.error || 'No checkout URL returned'); }
  } catch(err){
    console.error('sponsorWish error:', err);
    alert('Something went wrong connecting to Stripe. Please try again shortly.');
  }
}

