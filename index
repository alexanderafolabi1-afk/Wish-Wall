/* ============================================================
   PARTICLE SYSTEM
   ============================================================ */
const canvas = document.getElementById('px-canvas');
const ctx    = canvas.getContext('2d');
let particles  = [];

function resizeCanvas(){
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}

class Particle{
  constructor(){ this.reset(true); }
  reset(initial){
    this.x  = Math.random() * canvas.width;
    this.y  = initial ? Math.random() * canvas.height : canvas.height + 20;
    this.sz = Math.random() * 3.5 + 1;
    this.vy = -(Math.random() * 0.55 + 0.18);
    this.vx = (Math.random() - .5) * .35;
    this.op = Math.random() * .45 + .1;
    this.col= ['#FFE566','#FF4D8D','#00D4FF','#00FFB3','#FF7B2C','#B44DFF'][Math.floor(Math.random()*6)];
    this.isCirc = Math.random() > .45;
  }
  step(){
    this.y += this.vy;
    this.x += this.vx;
    this.op -= .00045;
    if(this.y < -20 || this.op <= 0) this.reset(false);
  }
  draw(){
    ctx.save();
    ctx.globalAlpha = this.op;
    ctx.fillStyle   = this.col;
    if(this.isCirc){
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.sz, 0, Math.PI*2);
      ctx.fill();
    } else {
      ctx.font = `${this.sz*3}px serif`;
      ctx.fillText('✦', this.x, this.y);
    }
    ctx.restore();
  }
}

function initPx(){
  resizeCanvas();
  particles = Array.from({length:55}, () => new Particle());
}
function animPx(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  particles.forEach(p => { p.step(); p.draw(); });
  requestAnimationFrame(animPx);
}
window.addEventListener('resize', resizeCanvas);
initPx();
animPx();

