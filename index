  { name:'Guardian',   icon:'🛡️', min:200,   max:999,  desc:'A true keeper of dreams. The wall thanks you.',    color:'#B44DFF' },
  { name:'Mythkeeper', icon:'🔮', min:1000,  max:Infinity, desc:'Legendary. Wishes bend toward you.',           color:'#FF4D8D' },
];

function getTier(totalDonated){
  return TIERS.slice().reverse().find(t => totalDonated >= t.min) || TIERS[0];
}

function renderGuardianTier(totalDonated = 0){
  const tier     = getTier(totalDonated);
  const nextTier = TIERS[TIERS.indexOf(tier) + 1];
  const pct      = nextTier
    ? Math.min(((totalDonated - tier.min) / (nextTier.min - tier.min)) * 100, 100)
    : 100;
  const container = document.getElementById('tier-banner');
  if(!container) return;
  container.innerHTML = `
    <div class="tier-icon">${tier.icon}</div>
    <div class="tier-body">
      <div class="tier-name" style="color:${tier.color}">${tier.name} Guardian</div>
      <div class="tier-desc">${tier.desc}</div>
      <div class="tier-track">
        <div class="tier-bar" style="width:${pct}%;background:linear-gradient(90deg,${tier.color},${nextTier?.color||tier.color})"></div>
      </div>
      <div class="tier-next">${nextTier ? `${(nextTier.min - totalDonated).toLocaleString()} to reach ${nextTier.name}` : '🎖️ Maximum tier reached'}</div>
    </div>`;
}
