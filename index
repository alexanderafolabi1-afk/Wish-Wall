}
.patron-tagline{
  font-family:var(--fn-note);font-size:1.05rem;
  color:rgba(255,255,255,.72);line-height:1.5;
}
.patron-amount{
  font-family:var(--fn-display);font-size:2.2rem;
  color:var(--green);text-shadow:var(--glow-green);
  white-space:nowrap;align-self:center;
}
.patron-desc{
  padding:0 28px 22px;
  font-family:var(--fn-note);font-size:1.05rem;
  color:rgba(255,255,255,.68);line-height:1.6;
}
.patron-footer{
  background:rgba(0,0,0,.25);
  padding:14px 28px;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;
  border-top:1px solid rgba(255,255,255,.07);
}
.patron-tags{display:flex;gap:8px;flex-wrap:wrap;}
.patron-tag{
  background:rgba(180,77,255,.18);border:1px solid rgba(180,77,255,.3);
  color:rgba(255,255,255,.75);border-radius:50px;
  font-size:11px;padding:3px 12px;font-family:var(--fn-ui);font-weight:600;
  letter-spacing:.3px;
}
.patron-link{
  font-family:var(--fn-display);font-size:14px;
  color:var(--purple);text-decoration:none;
  padding:7px 18px;border:1.5px solid rgba(180,77,255,.5);border-radius:50px;
  transition:all .2s;white-space:nowrap;
}
.patron-link:hover{background:rgba(180,77,255,.2);color:#fff;border-color:var(--purple);}

/* second patron — RenviaIT */
.patron-banner.renvia{
  border-color:rgba(0,212,255,.4);
  background:linear-gradient(135deg,rgba(0,212,255,.1) 0%,rgba(0,0,0,.5) 60%,rgba(0,255,179,.06) 100%);
  box-shadow:0 0 40px rgba(0,212,255,.14),0 4px 32px rgba(0,0,0,.35);
}
.patron-banner.renvia .patron-badge{background:linear-gradient(135deg,#00D4FF,#00FFB3);}
.patron-banner.renvia .patron-link{color:var(--blue);border-color:rgba(0,212,255,.5);}
.patron-banner.renvia .patron-link:hover{background:rgba(0,212,255,.2);color:#fff;border-color:var(--blue);}
.patron-banner.renvia .patron-tag{background:rgba(0,212,255,.12);border-color:rgba(0,212,255,.3);}
.patron-section-lbl{
  font-family:var(--fn-display);font-size:1.3rem;color:var(--yellow);
  text-align:center;margin:36px 0 18px;
  text-shadow:var(--glow-yellow);
}

/* Leaderboard */
.leaderboard{max-width:500px;margin:0 auto;}
.lb-title{font-family:var(--fn-display);font-size:1.6rem;color:var(--orange);text-align:center;margin-bottom:18px;}
.lb-item{
  display:flex;align-items:center;gap:14px;
  background:rgba(255,255,255,.05);border-radius:14px;
  padding:14px 18px;margin-bottom:10px;transition:all .2s;
}
.lb-item:hover{background:rgba(255,255,255,.09);}
.lb-rank{font-family:var(--fn-display);font-size:1.45rem;width:30px;text-align:center;}
.lb-rank.gold{color:#FFD700;}.lb-rank.silver{color:#C0C0C0;}.lb-rank.bronze{color:#CD7F32;}
.lb-name{flex:1;font-weight:600;color:#fff;}
.lb-amt{font-family:var(--fn-display);font-size:1.1rem;color:var(--green);}

/* ============================================================
   TRANSPARENCY LEDGER
   ============================================================ */
.ledger-section{
  position:relative;z-index:1;
  background:rgba(0,0,0,.42);
  border-top:1px solid rgba(255,255,255,.08);
  padding:48px 20px;
}
.ledger-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:18px;max-width:860px;margin:0 auto 22px;}
.led-card{text-align:center;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:24px 14px;}
.led-num{font-family:var(--fn-display);font-size:2.4rem;color:var(--yellow);display:block;margin-bottom:4px;}
.led-lbl{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.45);font-weight:700;}
.led-note{text-align:center;font-size:11px;color:rgba(255,255,255,.28);}

/* ============================================================
   FOOTER
   ============================================================ */
footer{
  position:relative;z-index:1;
  background:rgba(0,0,0,.6);
  border-top:1px solid rgba(255,255,255,.07);
  padding:40px 20px 28px;text-align:center;
  font-size:12px;color:rgba(255,255,255,.32);
}
footer a{color:var(--orange);text-decoration:none;transition:color .15s;}
footer a:hover{color:#fff;}
.footer-links{display:flex;flex-wrap:wrap;justify-content:center;gap:6px 22px;margin-bottom:14px;}
.footer-copy{font-size:11px;color:rgba(255,255,255,.18);margin-top:10px;}
.footer-trust{display:flex;justify-content:center;align-items:center;gap:16px;flex-wrap:wrap;margin:14px 0;}
.trust-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);
  border-radius:50px;padding:5px 13px;font-size:11px;font-weight:600;
  color:rgba(255,255,255,.45);
}

/* ============================================================
   MILESTONE PROGRESS BAR
   ============================================================ */
.milestone-wrap{
  max-width:520px;margin:18px auto 24px;
  background:rgba(0,0,0,.3);border-radius:14px;padding:14px 20px;
  border:1px solid rgba(255,255,255,.08);
}
.milestone-lbl{
  display:flex;justify-content:space-between;align-items:center;
  font-family:var(--fn-ui);font-size:12px;color:rgba(255,255,255,.6);
  margin-bottom:9px;
}
.milestone-badge{
  background:linear-gradient(135deg,var(--yellow),var(--orange));
  color:var(--ink);border-radius:50px;padding:3px 12px;
  font-size:11px;font-weight:700;letter-spacing:.3px;
}
.milestone-track{
  height:9px;background:rgba(255,255,255,.08);border-radius:50px;overflow:hidden;
}
.milestone-bar{
  height:100%;border-radius:50px;
  background:linear-gradient(90deg,var(--yellow),var(--orange));
  transition:width 1.1s cubic-bezier(.25,.46,.45,.94);
  box-shadow:0 0 14px rgba(255,229,102,.45);
}

/* ============================================================
   COOKIE CONSENT BANNER
   ============================================================ */
#cookie-banner{
  position:fixed;bottom:0;left:0;right:0;z-index:9999;
  background:rgba(18,8,0,.97);border-top:1px solid rgba(255,123,44,.3);
  padding:16px 24px;
  display:flex;align-items:center;justify-content:space-between;
  gap:16px;flex-wrap:wrap;
  backdrop-filter:blur(10px);
  transform:translateY(100%);transition:transform .45s cubic-bezier(.25,.46,.45,.94);
}
#cookie-banner.show{transform:translateY(0);}
.cookie-txt{font-size:12px;color:rgba(255,255,255,.62);font-family:var(--fn-ui);flex:1;min-width:220px;line-height:1.65;}
.cookie-txt a{color:var(--orange);text-decoration:none;}
.cookie-btns{display:flex;gap:10px;flex-wrap:wrap;}
.cookie-accept{
  background:var(--orange);color:#fff;border:none;border-radius:50px;
  padding:8px 22px;font-family:var(--fn-ui);font-weight:700;font-size:12px;
  cursor:pointer;transition:background .2s;white-space:nowrap;
}
.cookie-accept:hover{background:#e06520;}
.cookie-reject{
  background:transparent;color:rgba(255,255,255,.45);
  border:1px solid rgba(255,255,255,.18);border-radius:50px;
  padding:8px 16px;font-family:var(--fn-ui);font-size:12px;
  cursor:pointer;transition:all .2s;white-space:nowrap;
}
.cookie-reject:hover{border-color:rgba(255,255,255,.4);color:#fff;}

/* ============================================================
   GAMIFICATION — GUARDIAN TIER BADGE
   ============================================================ */
.tier-banner{
  max-width:520px;margin:0 auto 28px;
  background:linear-gradient(135deg,rgba(180,77,255,.12),rgba(0,0,0,.45));
  border:1px solid rgba(180,77,255,.28);border-radius:16px;
  padding:16px 22px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;
}
.tier-icon{font-size:2rem;line-height:1;flex-shrink:0;}
.tier-body{flex:1;min-width:160px;}
.tier-name{font-family:var(--fn-display);font-size:1.1rem;color:#fff;margin-bottom:2px;}
.tier-desc{font-size:11px;color:rgba(255,255,255,.48);font-family:var(--fn-ui);}
.tier-track{height:6px;background:rgba(255,255,255,.08);border-radius:50px;overflow:hidden;margin-top:8px;}
.tier-bar{height:100%;border-radius:50px;background:linear-gradient(90deg,var(--purple),var(--pink));transition:width .9s ease;}
.tier-next{font-size:10px;color:rgba(255,255,255,.3);font-family:var(--fn-ui);margin-top:4px;}

/* ============================================================
   MASCOT: WISHI
   ============================================================ */
.mascot-wrap{
  position:fixed;bottom:0;right:30px;z-index:50;
  cursor:pointer;transition:transform .3s;
  -webkit-tap-highlight-color:transparent;
}
.mascot-wrap:hover{transform:translateY(-8px);}
.mascot-bubble{
  position:absolute;bottom:100%;right:0;
  background:#fff;border-radius:16px 16px 4px 16px;
  padding:10px 14px;font-family:var(--fn-note);font-size:14px;
  color:var(--ink);max-width:190px;line-height:1.45;
  box-shadow:0 4px 22px rgba(0,0,0,.35);
  opacity:0;transform:scale(.8) translateY(10px);transform-origin:bottom right;
  transition:all .3s cubic-bezier(.175,.885,.32,1.275);
  pointer-events:none;
}
.mascot-wrap:hover .mascot-bubble,
.mascot-wrap.speaking .mascot-bubble{opacity:1;transform:scale(1) translateY(0);}
.mascot-svg{width:76px;height:88px;display:block;}

/* ============================================================
   MODAL
   ============================================================ */
.modal-overlay{
  position:fixed;inset:0;
  background:rgba(0,0,0,.78);backdrop-filter:blur(10px);
  z-index:200;display:flex;align-items:center;justify-content:center;
  padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;
}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{
  background:linear-gradient(145deg,#2C1300,#1A0A00);
  border:1px solid var(--orange);border-radius:26px;
  padding:36px;max-width:480px;width:100%;
  box-shadow:0 0 70px rgba(255,123,44,.28),0 32px 90px rgba(0,0,0,.7);
  transform:scale(.78) translateY(30px);
  transition:transform .35s cubic-bezier(.175,.885,.32,1.275);
  position:relative;max-height:90vh;overflow-y:auto;
}
.modal-overlay.open .modal{transform:scale(1) translateY(0);}
.modal-close{
  position:absolute;top:16px;right:16px;
  background:rgba(255,255,255,.1);border:none;color:#fff;
  width:32px;height:32px;border-radius:50%;cursor:pointer;
  font-size:18px;display:flex;align-items:center;justify-content:center;
  transition:background .2s;
}
.modal-close:hover{background:rgba(255,255,255,.2);}
.modal-title{font-family:var(--fn-display);font-size:2rem;color:var(--yellow);text-shadow:var(--glow-yellow);margin-bottom:6px;}
.modal-sub{font-family:var(--fn-note);color:rgba(255,255,255,.58);font-size:1rem;margin-bottom:26px;}

.form-field{margin-bottom:18px;}
.form-label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:rgba(255,255,255,.48);margin-bottom:8px;}
.form-req{color:var(--red);}
.form-inp,.form-ta{
  width:100%;background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.12);border-radius:13px;
  color:#fff;font-family:var(--fn-note);font-size:16px;
  padding:14px 16px;outline:none;transition:all .2s;resize:none;
}
.form-inp::placeholder,.form-ta::placeholder{color:rgba(255,255,255,.25);}
.form-inp:focus,.form-ta:focus{border-color:var(--yellow);box-shadow:0 0 0 3px rgba(255,229,102,.13);}
.char-ctr{text-align:right;font-size:11px;color:rgba(255,255,255,.35);margin-top:4px;}
.char-ctr.warn{color:var(--orange);}.char-ctr.danger{color:var(--red);}
.form-hint{font-size:11px;color:rgba(255,255,255,.3);margin-top:5px;}

.chk-wrap{display:flex;align-items:center;gap:10px;cursor:pointer;}
.chk-wrap input[type=checkbox]{width:20px;height:20px;accent-color:var(--yellow);cursor:pointer;}
.chk-lbl{font-size:14px;color:rgba(255,255,255,.8);}

.price-note{
  background:rgba(255,229,102,.09);border:1px solid rgba(255,229,102,.2);
  border-radius:14px;padding:14px 16px;
  font-size:13px;color:rgba(255,255,255,.7);
  margin-bottom:22px;display:flex;align-items:center;gap:12px;line-height:1.5;
}
.price-note strong{color:var(--yellow);}

.submit-btn{
  width:100%;padding:16px;border-radius:50px;border:none;
  background:linear-gradient(135deg,var(--pink),var(--purple));
  color:#fff;font-family:var(--fn-display);font-size:20px;
  cursor:pointer;box-shadow:var(--glow-pink);
  transition:all .2s;letter-spacing:.5px;
}
.submit-btn:hover{transform:scale(1.03);box-shadow:0 0 42px rgba(255,77,141,.85);}
.submit-btn:disabled{opacity:.45;cursor:not-allowed;transform:none;}

/* ============================================================
   CONFIRMATION SCREEN
   ============================================================ */
.confirm-ov{
  position:fixed;inset:0;z-index:300;
  background:radial-gradient(circle at center,#1E0A00 0%,#000 100%);
  display:none;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:40px;
}
.confirm-ov.show{display:flex;animation:fadeIn .4s ease;}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
.confirm-title{
  font-family:var(--fn-display);font-size:clamp(2rem,6vw,3.4rem);
  color:var(--yellow);text-shadow:var(--glow-yellow);margin-bottom:14px;
}
.confirm-sub{font-family:var(--fn-note);font-size:1.15rem;color:rgba(255,255,255,.68);margin-bottom:12px;}
.confirm-note{
  width:230px;background:var(--yellow);border-radius:4px;
  padding:24px;box-shadow:8px 12px 44px rgba(0,0,0,.52);
  margin:0 auto 28px;transform:rotate(-2.5deg);
}
.confirm-note-txt{font-family:var(--fn-note);font-size:1.1rem;color:var(--ink);line-height:1.5;}
.share-row{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:22px;}
.share-btn{
  padding:12px 24px;border-radius:50px;
  border:2px solid rgba(255,255,255,.3);background:transparent;
  color:#fff;font-family:var(--fn-ui);font-weight:600;font-size:13px;
  cursor:pointer;transition:all .2s;
}
.share-btn:hover{background:rgba(255,255,255,.1);border-color:#fff;}
.back-btn{
  padding:14px 38px;border-radius:50px;border:none;
  background:var(--orange);color:#fff;font-family:var(--fn-display);
  font-size:18px;cursor:pointer;transition:all .2s;
  box-shadow:0 4px 22px rgba(255,123,44,.45);
}
.back-btn:hover{transform:scale(1.05);}

/* ============================================================
   CONFETTI PIECES
   ============================================================ */
.conf-piece{
  position:fixed;pointer-events:none;border-radius:2px;
  animation:confFall linear forwards;z-index:1000;
}
@keyframes confFall{
  0%{transform:translateY(-80px) rotate(0deg);opacity:1;}
  100%{transform:translateY(110vh) rotate(720deg);opacity:0;}
}

/* ============================================================
   HOW IT WORKS TAB
   ============================================================ */
.how-card{
  border-radius:22px;padding:28px;display:flex;gap:20px;align-items:flex-start;
  margin-bottom:20px;
}
.how-card-icon{font-size:2.6rem;flex-shrink:0;}
.how-card-title{font-family:var(--fn-display);font-size:1.4rem;margin-bottom:8px;}
.how-card-body{font-family:var(--fn-note);font-size:1rem;color:rgba(255,255,255,.7);line-height:1.65;}

/* ============================================================
   SCROLL TO TOP
   ============================================================ */
.scr-top{
  position:fixed;bottom:106px;right:20px;
  width:44px;height:44px;border-radius:50%;
  background:var(--orange);border:none;color:#fff;
  font-size:18px;cursor:pointer;z-index:40;
  box-shadow:0 4px 20px rgba(255,123,44,.5);
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;opacity:0;pointer-events:none;
}
.scr-top.vis{opacity:1;pointer-events:all;}
.scr-top:hover{transform:scale(1.12);}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media(max-width:768px){
  header{
    height:auto;flex-wrap:wrap;
    padding:10px 14px;gap:8px;
  }
  nav{order:3;width:100%;overflow-x:auto;padding-bottom:2px;gap:3px;}
  .nav-tab{font-size:12px;padding:7px 12px;}
  .wall-grid{columns:2 145px;column-gap:10px;}
  .wall-section{padding:12px;}
  .hero{padding:36px 16px 20px;}
  .hero-stats{gap:10px;}
  .mascot-wrap{right:10px;}
  .modal{padding:24px;}
  .edu-card{padding:24px;}
  .edu-title{font-size:1.7rem;}
  .calc-big{font-size:3.2rem;}
  .logo-txt{font-size:20px;}
}
@media(max-width:420px){
  .wall-grid{columns:2 120px;column-gap:8px;}
  .logo-txt{display:none;}
  .pin-btn{font-size:14px;padding:9px 16px;}
}
</style>

