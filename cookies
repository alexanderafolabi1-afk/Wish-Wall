<script>
function acceptAll(){
  localStorage.setItem('ww-cookie-consent','all');
  alert('✅ Cookie preferences saved — all cookies accepted.');
}
function essentialOnly(){
  localStorage.setItem('ww-cookie-consent','essential');
  alert('✅ Cookie preferences saved — essential cookies only.');
}
</script>
