<!-- Firebase SDK -->
<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
  import {
    getFirestore, collection, getDocs, doc, updateDoc, deleteDoc,
    query, orderBy, getDoc, setDoc, serverTimestamp, onSnapshot
  } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

  // ⚠️ Same config as index.html
  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    projectId: "YOUR_PROJECT_ID",
    storageBucket: "YOUR_PROJECT.appspot.com",
    messagingSenderId: "YOUR_SENDER_ID",
    appId: "YOUR_APP_ID"
  };

  try {
    const app = initializeApp(firebaseConfig);
    const db  = getFirestore(app);

    window._db  = db;
    window._col = { wishes: collection(db, 'wishes'), ledger: doc(db, 'meta', 'ledger') };
    window._ops = { getDocs, doc, updateDoc, deleteDoc, query, orderBy, getDoc, setDoc, serverTimestamp, onSnapshot };

    window.fbApprove = async (id) => {
      await updateDoc(doc(db,'wishes',id), { status:'approved', approvedAt: serverTimestamp() });
    };
    window.fbGrant = async (id, cost) => {
      await updateDoc(doc(db,'wishes',id), { status:'granted', grantedAt: serverTimestamp(), grantCost: cost });
    };
    window.fbDelete = async (id) => {
      await deleteDoc(doc(db,'wishes',id));
    };
    window.fbUpdateLedger = async (data) => {
      await setDoc(doc(db,'meta','ledger'), { ...data, updatedAt: serverTimestamp() }, { merge: true });
    };
    window.fbAddCheekyResponse = async (id, response) => {
      await updateDoc(doc(db,'wishes',id), { cheekyResponse: response, respondedAt: serverTimestamp() });
    };

    // Load all wishes (admin sees everything)
    const q = query(window._col.wishes, orderBy('createdAt','desc'));
    onSnapshot(q, snap => {
      const all = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      window.renderAdmin(all);
    });

    window._fbReady = true;
  } catch(e) {
    console.warn('Firebase not configured:', e.message);
    window._fbReady = false;
  }
</script>

