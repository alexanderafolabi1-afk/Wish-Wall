</div>

<!-- ADMIN PANEL -->
<div class="admin-wrap" id="adm-wrap">

  <div class="adm-header">
    <div>
      <span class="adm-logo">🧱 Wish Wall Admin</span>
      <span class="adm-domain"> · wishwall.xyz</span>
    </div>
    <button class="adm-logout" onclick="logout()">Log out</button>
  </div>

  <div class="adm-body">

    <!-- Stats -->
    <div class="adm-stats">
      <div class="adm-stat"><span class="adm-stat-num" id="a-total">0</span><span class="adm-stat-lbl">Total Wishes</span></div>
      <div class="adm-stat"><span class="adm-stat-num" id="a-pending">0</span><span class="adm-stat-lbl">Pending Review</span></div>
      <div class="adm-stat"><span class="adm-stat-num" id="a-approved">0</span><span class="adm-stat-lbl">Live on Wall</span></div>
      <div class="adm-stat"><span class="adm-stat-num" id="a-granted">0</span><span class="adm-stat-lbl">Granted ✅</span></div>
    </div>

    <!-- Ledger Editor -->
    <!--
      NOTE: Pot balance is intentionally NOT displayed publicly on wishwall.xyz
      per platform policy. This admin editor is for internal tracking only.
      The public Transparency Ledger shows: fees collected, donations, granted
      count, and avg cost — but NOT the current pot balance.
    -->
    <div class="led-editor">
      <h3>📊 Update Transparency Ledger</h3>
      <p>⚠️ The pot balance is NOT publicly visible on wishwall.xyz — internal tracking only. The public ledger shows fees, donations, granted count, and avg cost.</p>
      <div class="led-fields">
        <div class="led-field"><label>Wish Fees Collected (£)</label><input type="number" id="l-fees" value="300" min="0"></div>
        <div class="led-field"><label>Guardian Donations (£)</label><input type="number" id="l-don" value="14620" min="0"></div>
        <div class="led-field"><label>Wishes Granted</label><input type="number" id="l-gr" value="60" min="0"></div>
        <div class="led-field"><label>Avg Cost Per Wish (£)</label><input type="number" id="l-avg" value="45" min="0"></div>
        <div class="led-field"><label>Pot Balance (£) — Internal</label><input type="number" id="l-pot" value="9720" min="0"></div>
      </div>
      <button class="led-save" onclick="saveLedger()">💾 Save Ledger</button>
      <p class="led-note">Pot balance is stored in Firestore but never served to the public interface.</p>
    </div>

    <!-- Toolbar -->
    <div class="adm-toolbar">
      <input class="adm-search" type="text" id="adm-srch" placeholder="🔍 Search wishes, emails, names..." oninput="filterAdm()">
      <button class="adm-filter on" onclick="setAdmFilter('all',this)">All</button>
      <button class="adm-filter" onclick="setAdmFilter('pending',this)">⏳ Pending</button>
      <button class="adm-filter" onclick="setAdmFilter('approved',this)">🌟 Live</button>
      <button class="adm-filter" onclick="setAdmFilter('granted',this)">✅ Granted</button>
    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
      <table class="wish-table" id="adm-table">
        <thead>
          <tr>
            <th>Wish</th>
            <th>Wisher</th>
            <th>Email</th>
            <th>Country</th>
            <th>Date</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="adm-tbody">
          <tr><td colspan="7" style="text-align:center;padding:40px;color:rgba(255,255,255,.4);">Loading wishes...</td></tr>
        </tbody>
      </table>
    </div>

  </div>
</div>

<!-- Grant Modal -->
<div class="grant-modal" id="grant-modal">
  <div class="grant-box">
    <h3>✅😊 Mark as Granted</h3>
    <p>Record the cost to grant this wish (optional). The note will be ticked green with a smile on the wall.</p>
    <input class="grant-inp" type="number" id="grant-cost" placeholder="Cost in £ (optional)" min="0">
    <div class="grant-btns">
      <button class="grant-ok" onclick="confirmGrant()">Grant It ✨</button>
      <button class="grant-cancel" onclick="closeGrantModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- Respond Modal (cheeky stamp) -->
<div class="respond-modal" id="respond-modal">
  <div class="respond-box">
    <h3>💜 Add a Response Stamp</h3>
    <p>For cheeky, funny, or sweet wishes — stamp it with a response. This appears as a small badge on the note.</p>
    <div class="respond-presets">
      <span class="respond-preset" onclick="setResponse('😂 We love you')">😂 We love you</span>
      <span class="respond-preset" onclick="setResponse('🔥 Respect.')">🔥 Respect.</span>
      <span class="respond-preset" onclick="setResponse('💛 We see you')">💛 We see you</span>
      <span class="respond-preset" onclick="setResponse('🌪️ Absolutely not. And yet.')">🌪️ Absolutely not. And yet.</span>
      <span class="respond-preset" onclick="setResponse('✨ This is the way.')">✨ This is the way.</span>
      <span class="respond-preset" onclick="setResponse('🙏 Prayers submitted.')">🙏 Prayers submitted.</span>
      <span class="respond-preset" onclick="setResponse('👑 Iconic.')">👑 Iconic.</span>
      <span class="respond-preset" onclick="setResponse('💌 Thank you for being here.')">💌 Thank you for being here.</span>
    </div>
    <textarea class="respond-inp" id="respond-txt" placeholder="Or type a custom response..." rows="3"></textarea>
    <div class="grant-btns">
      <button class="grant-ok" style="background:var(--purple)" onclick="confirmRespond()">Stamp It 💜</button>
      <button class="grant-cancel" onclick="closeRespondModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
'use strict';

/* ============================================================
   AUTH — simple password gate
   ⚠️  For production: replace with Firebase Auth or equivalent
   Contact: admin@wallwishes.xyz
   ============================================================ */
const ADMIN_PW  = 'wishwall2025'; // ⚠️ CHANGE BEFORE DEPLOYING
const ADMIN_KEY = 'ww_admin_auth';

let allAdmWishes    = [];
let admFilter       = 'all';
let admSearch       = '';
let grantTargetId   = null;
let respondTargetId = null;

function login(){
  const pw = document.getElementById('adm-pw').value;
  if(pw === ADMIN_PW){
    sessionStorage.setItem(ADMIN_KEY, '1');
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('adm-wrap').classList.add('show');
    loadDemoIfNeeded();
  } else {
    document.getElementById('login-err').textContent = '❌ Wrong password. Try again.';
    document.getElementById('adm-pw').value = '';
  }
}

function logout(){
  sessionStorage.removeItem(ADMIN_KEY);
  location.reload();
}

if(sessionStorage.getItem(ADMIN_KEY)){
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('adm-wrap').classList.add('show');
  loadDemoIfNeeded();
}

/* ============================================================
   RENDER ADMIN TABLE
   ============================================================ */
window.renderAdmin = function(wishes){
  allAdmWishes = wishes;
  updateAdmStats();
  paintTable();
};

function updateAdmStats(){
  document.getElementById('a-total').textContent    = allAdmWishes.length;
  document.getElementById('a-pending').textContent  = allAdmWishes.filter(w=>w.status==='pending').length;
  document.getElementById('a-approved').textContent = allAdmWishes.filter(w=>w.status==='approved').length;
  document.getElementById('a-granted').textContent  = allAdmWishes.filter(w=>w.status==='granted').length;
}

function paintTable(){
  const tbody = document.getElementById('adm-tbody');
  let src = allAdmWishes;

  if(admFilter !== 'all') src = src.filter(w => w.status === admFilter);
  if(admSearch){
    const q = admSearch.toLowerCase();
    src = src.filter(w =>
      (w.wishText||'').toLowerCase().includes(q) ||
      (w.email||'').toLowerCase().includes(q) ||
      (w.name||'').toLowerCase().includes(q)
    );
  }

  if(!src.length){
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:rgba(255,255,255,.4);">No wishes found ✨</td></tr>';
    return;
  }

  tbody.innerHTML = src.map(w => {
    let dateStr = '—';
    try{
      const d = w.createdAt?.toDate ? w.createdAt.toDate() : (w.createdAt ? new Date(w.createdAt) : null);
      if(d) dateStr = d.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'2-digit'});
    }catch(_){}

    const statusCls = {pending:'s-pending',approved:'s-approved',granted:'s-granted'}[w.status] || 's-pending';

    const actions = [];
    if(w.status === 'pending')  actions.push(`<button class="act-btn btn-approve" onclick="approve('${esc(w.id)}')">✅ Approve</button>`);
    if(w.status !== 'granted')  actions.push(`<button class="act-btn btn-grant"   onclick="grantWish('${esc(w.id)}')">🎉 Grant</button>`);
    actions.push(`<button class="act-btn btn-respond" onclick="respondWish('${esc(w.id)}')">💜 Respond</button>`);
    actions.push(`<button class="act-btn btn-del"     onclick="del('${esc(w.id)}')">🗑 Delete</button>`);

    return `
<tr class="wish-row">
  <td>
    <div class="wish-txt">${esc(w.wishText)}</div>
    ${w.anonymous ? '<div class="wish-meta">🕶️ Anonymous post</div>' : ''}
    ${w.cheekyResponse ? `<div class="wish-meta">💜 Response: "${esc(w.cheekyResponse)}"</div>` : ''}
    ${w.isConnect ? '<div class="wish-meta">🤝 Connection wish</div>' : ''}
    ${w.grantCost ? `<div class="wish-meta">💷 Grant cost: £${w.grantCost}</div>` : ''}
  </td>
  <td style="font-size:13px;color:rgba(255,255,255,.7);">${esc(w.name || '—')}</td>
  <td style="font-size:12px;color:rgba(255,255,255,.5);">${esc(w.email || '—')}</td>
  <td style="font-size:12px;">${esc(w.country || '—')}</td>
  <td style="font-size:12px;color:rgba(255,255,255,.5);white-space:nowrap;">${dateStr}</td>
  <td><span class="status-pill ${statusCls}">${w.status}</span></td>
  <td style="white-space:nowrap;">${actions.join('')}</td>
</tr>`;
  }).join('');
}

function esc(s=''){
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

/* ============================================================
   FILTER & SEARCH
   ============================================================ */
function setAdmFilter(f, btn){
  admFilter = f;
  document.querySelectorAll('.adm-filter').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  paintTable();
}
function filterAdm(){
  admSearch = document.getElementById('adm-srch').value.trim();
  paintTable();
}

/* ============================================================
   ACTIONS
   ============================================================ */
async function approve(id){
  if(!confirm('Approve this wish and make it live on the wall?')) return;
  try{
    if(window.fbApprove) await window.fbApprove(id);
    else { const w = allAdmWishes.find(x=>x.id===id); if(w) w.status='approved'; updateAdmStats(); paintTable(); }
    toast('✅ Wish approved and live on wishwall.xyz!');
  } catch(e){ toast('❌ Error: '+e.message,'red'); }
}

function grantWish(id){
  grantTargetId = id;
  document.getElementById('grant-cost').value = '';
  document.getElementById('grant-modal').classList.add('open');
}
function closeGrantModal(){
  document.getElementById('grant-modal').classList.remove('open');
  grantTargetId = null;
}
async function confirmGrant(){
  if(!grantTargetId) return;
  const cost = parseFloat(document.getElementById('grant-cost').value) || 0;
  try{
    if(window.fbGrant) await window.fbGrant(grantTargetId, cost);
    else { const w = allAdmWishes.find(x=>x.id===grantTargetId); if(w){ w.status='granted'; w.grantCost=cost; } updateAdmStats(); paintTable(); }
    closeGrantModal();
    toast('🎉 Wish granted! Note ticked green with smile on the wall.');
  } catch(e){ toast('❌ Error: '+e.message,'red'); }
}

function respondWish(id){
  respondTargetId = id;
  document.getElementById('respond-txt').value = '';
  document.getElementById('respond-modal').classList.add('open');
}
function closeRespondModal(){
  document.getElementById('respond-modal').classList.remove('open');
  respondTargetId = null;
}
function setResponse(txt){
  document.getElementById('respond-txt').value = txt;
}
async function confirmRespond(){
  if(!respondTargetId) return;
  const response = document.getElementById('respond-txt').value.trim();
  if(!response){ toast('Please enter a response.','red'); return; }
  try{
    if(window.fbAddCheekyResponse) await window.fbAddCheekyResponse(respondTargetId, response);
    else { const w = allAdmWishes.find(x=>x.id===respondTargetId); if(w) w.cheekyResponse = response; paintTable(); }
    closeRespondModal();
    toast('💜 Response stamped on the wish!');
  } catch(e){ toast('❌ Error: '+e.message,'red'); }
}

document.getElementById('grant-modal').addEventListener('click', e => {
  if(e.target===document.getElementById('grant-modal')) closeGrantModal();
});
document.getElementById('respond-modal').addEventListener('click', e => {
  if(e.target===document.getElementById('respond-modal')) closeRespondModal();
});

async function del(id){
  if(!confirm('Permanently delete this wish? This cannot be undone.')) return;
  try{
    if(window.fbDelete) await window.fbDelete(id);
    else { allAdmWishes = allAdmWishes.filter(x=>x.id!==id); updateAdmStats(); paintTable(); }
    toast('🗑 Wish deleted.');
  } catch(e){ toast('❌ Error: '+e.message,'red'); }
}

/* ============================================================
   LEDGER
   ============================================================ */
async function saveLedger(){
  const data = {
    totalFees:       parseFloat(document.getElementById('l-fees').value) || 0,
    totalDonations:  parseFloat(document.getElementById('l-don').value)  || 0,
    totalGranted:    parseInt(document.getElementById('l-gr').value)     || 0,
    avgCost:         parseFloat(document.getElementById('l-avg').value)  || 0,
    potBalance:      parseFloat(document.getElementById('l-pot').value)  || 0, // internal only, never exposed publicly
  };
  try{
    if(window.fbUpdateLedger) await window.fbUpdateLedger(data);
    toast('💾 Ledger saved! Pot balance stored internally, not shown publicly on wishwall.xyz.');
  } catch(e){ toast('❌ Ledger save failed: '+e.message,'red'); }
}

/* ============================================================
   TOAST
   ============================================================ */
let toastTimer;
function toast(msg, type='green'){
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.style.borderColor = type === 'red' ? 'var(--red)' : 'var(--green)';
  el.style.color = type === 'red' ? 'var(--red)' : 'var(--green)';
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3500);
}

/* ============================================================
   DEMO DATA
   ============================================================ */
function loadDemoIfNeeded(){
  if(!window._fbReady){
    setTimeout(() => {
      window.renderAdmin([
        {id:'d1',wishText:"I wish for enough to fix my mum's roof 🏠",name:'Jane D.',email:'jane@example.com',status:'pending',anonymous:false,country:'🇬🇧 UK',createdAt:null},
        {id:'d2',wishText:"I wish to finally finish my novel 📖",name:'',email:'anon@example.com',status:'approved',anonymous:true,country:'🌍 Global',createdAt:null},
        {id:'d3',wishText:"My ex sees me thriving and it haunts him gently. Forever 💅",name:'',email:'anon2@example.com',status:'approved',anonymous:true,country:'🇬🇧 UK',createdAt:null},
        {id:'d4',wishText:"I wish my dog gets better soon 🐕",name:'Tom S.',email:'tom@example.com',status:'granted',anonymous:false,country:'🇬🇧 UK',createdAt:null,grantCost:35},
        {id:'d5',wishText:"Help me reach my car fund. Rural area — no car means no job 🚗",name:'',email:'anon3@example.com',status:'approved',anonymous:true,country:'🇬🇧 UK',createdAt:null},
        {id:'d6',wishText:"Just a hug from someone who means it. That's it. 🤗",name:'',email:'anon4@example.com',status:'granted',anonymous:true,country:'🌍 Global',createdAt:null,cheekyResponse:'💛 We see you'},
        {id:'d7',wishText:"Connect me to a food bank in my area — just moved, have nothing 🤝",name:'',email:'anon5@example.com',status:'approved',anonymous:true,country:'🇬🇧 UK',isConnect:true,createdAt:null},
      ]);
    }, 500);
  }
}
</script>

</body>
</html>
