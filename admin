<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wish Wall Admin 🔐 — wishwall.xyz</title>
<meta name="robots" content="noindex,nofollow">
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&family=Boogaloo&family=Caveat:wght@600&display=swap" rel="stylesheet">

<!-- Firebase SDK -->
<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
  import {
    getFirestore, collection, getDocs, doc, updateDoc, deleteDoc,
    query, orderBy, getDoc, setDoc, serverTimestamp, onSnapshot
  } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

  // ⚠️ Same config as index.html
  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    projectId: "YOUR_PROJECT_ID",
    storageBucket: "YOUR_PROJECT.appspot.com",
    messagingSenderId: "YOUR_SENDER_ID",
    appId: "YOUR_APP_ID"
  };

  try {
    const app = initializeApp(firebaseConfig);
    const db  = getFirestore(app);

    window._db  = db;
    window._col = { wishes: collection(db, 'wishes'), ledger: doc(db, 'meta', 'ledger') };
    window._ops = { getDocs, doc, updateDoc, deleteDoc, query, orderBy, getDoc, setDoc, serverTimestamp, onSnapshot };

    window.fbApprove = async (id) => {
      await updateDoc(doc(db,'wishes',id), { status:'approved', approvedAt: serverTimestamp() });
    };
    window.fbGrant = async (id, cost) => {
      await updateDoc(doc(db,'wishes',id), { status:'granted', grantedAt: serverTimestamp(), grantCost: cost });
    };
    window.fbDelete = async (id) => {
      await deleteDoc(doc(db,'wishes',id));
    };
    window.fbUpdateLedger = async (data) => {
      await setDoc(doc(db,'meta','ledger'), { ...data, updatedAt: serverTimestamp() }, { merge: true });
    };
    window.fbAddCheekyResponse = async (id, response) => {
      await updateDoc(doc(db,'wishes',id), { cheekyResponse: response, respondedAt: serverTimestamp() });
    };

    // Load all wishes (admin sees everything)
    const q = query(window._col.wishes, orderBy('createdAt','desc'));
    onSnapshot(q, snap => {
      const all = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      window.renderAdmin(all);
    });

    window._fbReady = true;
  } catch(e) {
    console.warn('Firebase not configured:', e.message);
    window._fbReady = false;
  }
</script>

<style>
:root{
  --yellow:#FFE566;--pink:#FF4D8D;--blue:#00D4FF;--green:#00FFB3;
  --orange:#FF7B2C;--purple:#B44DFF;--red:#FF3366;--green-dk:#00C484;
  --bg:#0A0500;--surface:#161006;--border:rgba(255,255,255,.1);
  --fn:'Quicksand',sans-serif;--fn-d:'Boogaloo',cursive;--fn-n:'Caveat',cursive;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--fn);background:var(--bg);color:#fff;min-height:100vh;}

/* LOGIN SCREEN */
.login-screen{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:radial-gradient(circle at 50% 40%,#200A00,#000);
}
.login-card{
  background:linear-gradient(145deg,#1C0C00,#100800);
  border:1px solid var(--orange);border-radius:24px;
  padding:44px;max-width:380px;width:100%;text-align:center;
  box-shadow:0 0 60px rgba(255,123,44,.25),0 30px 80px rgba(0,0,0,.7);
}
.login-icon{font-size:3rem;margin-bottom:16px;}
.login-title{font-family:var(--fn-d);font-size:2rem;color:var(--yellow);margin-bottom:8px;}
.login-sub{font-size:13px;color:rgba(255,255,255,.45);margin-bottom:28px;}
.adm-inp{
  width:100%;background:rgba(255,255,255,.07);border:1px solid var(--border);
  border-radius:12px;color:#fff;font-family:var(--fn);font-size:15px;
  padding:14px 16px;outline:none;transition:all .2s;margin-bottom:14px;
}
.adm-inp:focus{border-color:var(--orange);box-shadow:0 0 0 3px rgba(255,123,44,.12);}
.adm-inp::placeholder{color:rgba(255,255,255,.25);}
.login-btn{
  width:100%;padding:15px;border-radius:50px;border:none;
  background:linear-gradient(135deg,var(--orange),var(--pink));
  color:#fff;font-family:var(--fn-d);font-size:19px;cursor:pointer;
  box-shadow:0 4px 20px rgba(255,123,44,.45);transition:all .2s;
}
.login-btn:hover{transform:scale(1.04);}
.login-err{color:var(--red);font-size:12px;margin-top:10px;}
.login-domain{font-size:11px;color:rgba(255,255,255,.25);margin-top:14px;}

/* ADMIN LAYOUT */
.admin-wrap{display:none;}
.admin-wrap.show{display:block;}
.adm-header{
  background:linear-gradient(135deg,rgba(20,8,0,.98),rgba(45,18,0,.98));
  border-bottom:2px solid var(--orange);
  padding:0 28px;height:64px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;
  gap:16px;
}
.adm-logo{font-family:var(--fn-d);font-size:22px;color:var(--yellow);}
.adm-domain{font-size:11px;color:rgba(255,255,255,.3);}
.adm-logout{
  background:rgba(255,255,255,.08);border:1px solid var(--border);
  border-radius:50px;color:rgba(255,255,255,.6);padding:8px 18px;
  font-family:var(--fn);font-size:13px;font-weight:600;cursor:pointer;
  transition:all .2s;
}
.adm-logout:hover{background:var(--red);border-color:var(--red);color:#fff;}

.adm-body{padding:28px;max-width:1400px;margin:0 auto;}

/* Stats bar */
.adm-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:28px;}
.adm-stat{
  background:rgba(255,255,255,.04);border:1px solid var(--border);
  border-radius:16px;padding:20px 16px;text-align:center;
}
.adm-stat-num{font-family:var(--fn-d);font-size:2rem;color:var(--yellow);display:block;margin-bottom:4px;}
.adm-stat-lbl{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.45);font-weight:700;}

/* Toolbar */
.adm-toolbar{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:20px;}
.adm-search{
  background:rgba(255,255,255,.06);border:1px solid var(--border);
  border-radius:50px;color:#fff;padding:10px 18px;
  font-family:var(--fn);font-size:14px;outline:none;flex:1;min-width:200px;
}
.adm-search:focus{border-color:var(--yellow);}
.adm-filter{
  background:rgba(255,255,255,.06);border:1px solid var(--border);
  border-radius:50px;color:rgba(255,255,255,.6);padding:10px 16px;
  font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap;
}
.adm-filter.on,.adm-filter:hover{background:var(--orange);border-color:var(--orange);color:#fff;}

/* Wish table */
.wish-table{width:100%;border-collapse:separate;border-spacing:0 8px;}
.wish-table th{
  font-size:11px;text-transform:uppercase;letter-spacing:.8px;
  color:rgba(255,255,255,.4);font-weight:700;
  padding:8px 14px;text-align:left;
}
.wish-row{background:rgba(255,255,255,.04);transition:background .2s;}
.wish-row:hover{background:rgba(255,255,255,.07);}
.wish-row td{padding:14px;border-top:1px solid rgba(255,255,255,.05);border-bottom:1px solid rgba(255,255,255,.05);}
.wish-row td:first-child{border-left:1px solid rgba(255,255,255,.05);border-radius:12px 0 0 12px;}
.wish-row td:last-child{border-right:1px solid rgba(255,255,255,.05);border-radius:0 12px 12px 0;}

.wish-txt{font-family:var(--fn-n);font-size:16px;color:#fff;max-width:380px;line-height:1.4;}
.wish-meta{font-size:11px;color:rgba(255,255,255,.35);margin-top:4px;}

.status-pill{
  display:inline-block;padding:4px 12px;border-radius:50px;
  font-size:11px;font-weight:700;letter-spacing:.4px;
}
.s-pending{background:rgba(255,229,102,.15);color:var(--yellow);}
.s-approved{background:rgba(0,212,255,.15);color:var(--blue);}
.s-granted{background:rgba(0,196,132,.2);color:var(--green);}

.act-btn{
  padding:7px 14px;border-radius:50px;border:none;cursor:pointer;
  font-family:var(--fn);font-size:12px;font-weight:700;
  transition:all .2s;margin:2px;white-space:nowrap;
}
.btn-approve{background:rgba(0,212,255,.18);color:var(--blue);}
.btn-approve:hover{background:var(--blue);color:#000;}
.btn-grant{background:rgba(0,196,132,.18);color:var(--green-dk);}
.btn-grant:hover{background:var(--green-dk);color:#fff;}
.btn-respond{background:rgba(180,77,255,.18);color:var(--purple);}
.btn-respond:hover{background:var(--purple);color:#fff;}
.btn-del{background:rgba(255,51,102,.18);color:var(--red);}
.btn-del:hover{background:var(--red);color:#fff;}

/* Ledger editor */
.led-editor{
  background:rgba(255,255,255,.03);border:1px solid var(--border);
  border-radius:20px;padding:28px;margin-bottom:28px;
}
.led-editor h3{font-family:var(--fn-d);font-size:1.4rem;color:var(--yellow);margin-bottom:6px;}
.led-editor p{font-size:12px;color:rgba(255,255,255,.4);margin-bottom:18px;}
.led-fields{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:16px;}
.led-field label{font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:rgba(255,255,255,.4);font-weight:700;display:block;margin-bottom:6px;}
.led-field input{
  width:100%;background:rgba(255,255,255,.07);border:1px solid var(--border);
  border-radius:10px;color:#fff;font-family:var(--fn);font-size:14px;
  padding:10px 14px;outline:none;
}
.led-field input:focus{border-color:var(--yellow);}
.led-save{
  padding:12px 28px;border-radius:50px;border:none;
  background:var(--green-dk);color:#fff;font-family:var(--fn-d);font-size:16px;
  cursor:pointer;transition:all .2s;
}
.led-save:hover{transform:scale(1.04);}
.led-note{font-size:11px;color:rgba(255,255,255,.25);margin-top:10px;}

/* Toast */
.toast{
  position:fixed;bottom:24px;right:24px;z-index:999;
  background:#1A0800;border:1px solid var(--green);border-radius:14px;
  padding:14px 22px;font-size:14px;color:var(--green);
  box-shadow:0 4px 24px rgba(0,0,0,.6);
  transform:translateY(80px);opacity:0;transition:all .3s;pointer-events:none;
}
.toast.show{transform:translateY(0);opacity:1;}

/* Grant modal */
.grant-modal{
  position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:300;
  display:none;align-items:center;justify-content:center;padding:20px;
}
.grant-modal.open{display:flex;}
.grant-box{
  background:linear-gradient(145deg,#1C0C00,#100800);border:1px solid var(--green);
  border-radius:22px;padding:32px;max-width:380px;width:100%;
  box-shadow:0 0 50px rgba(0,196,132,.2);
}
.grant-box h3{font-family:var(--fn-d);font-size:1.5rem;color:var(--green);margin-bottom:8px;}
.grant-box p{font-size:13px;color:rgba(255,255,255,.55);margin-bottom:20px;}
.grant-inp{
  width:100%;background:rgba(255,255,255,.07);border:1px solid var(--border);
  border-radius:12px;color:#fff;font-family:var(--fn);font-size:16px;
  padding:14px;outline:none;margin-bottom:16px;
}
.grant-inp:focus{border-color:var(--green);}
.grant-btns{display:flex;gap:10px;}
.grant-ok{flex:1;padding:13px;border-radius:50px;border:none;background:var(--green-dk);color:#fff;font-family:var(--fn-d);font-size:17px;cursor:pointer;}
.grant-cancel{padding:13px 20px;border-radius:50px;border:1px solid var(--border);background:transparent;color:rgba(255,255,255,.6);font-family:var(--fn);font-size:14px;cursor:pointer;}

/* Respond modal */
.respond-modal{
  position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:300;
  display:none;align-items:center;justify-content:center;padding:20px;
}
.respond-modal.open{display:flex;}
.respond-box{
  background:linear-gradient(145deg,#1C0C00,#100800);border:1px solid var(--purple);
  border-radius:22px;padding:32px;max-width:420px;width:100%;
  box-shadow:0 0 50px rgba(180,77,255,.2);
}
.respond-box h3{font-family:var(--fn-d);font-size:1.5rem;color:var(--purple);margin-bottom:8px;}
.respond-box p{font-size:13px;color:rgba(255,255,255,.55);margin-bottom:16px;}
.respond-presets{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.respond-preset{
  padding:6px 14px;border-radius:50px;background:rgba(180,77,255,.15);
  border:1px solid rgba(180,77,255,.3);color:rgba(255,255,255,.75);
  font-size:12px;cursor:pointer;transition:all .15s;
}
.respond-preset:hover{background:rgba(180,77,255,.35);color:#fff;}
.respond-inp{
  width:100%;background:rgba(255,255,255,.07);border:1px solid var(--border);
  border-radius:12px;color:#fff;font-family:'Caveat',cursive;font-size:17px;
  padding:14px;outline:none;margin-bottom:16px;resize:vertical;min-height:80px;
}
.respond-inp:focus{border-color:var(--purple);}

@media(max-width:768px){
  .adm-body{padding:16px;}
  .wish-table{display:block;overflow-x:auto;}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div class="login-screen" id="login-screen">
  <div class="login-card">
    <div class="login-icon">🔐</div>
    <h2 class="login-title">Admin Portal</h2>
    <p class="login-sub">The Wish Wall — management console</p>
    <input class="adm-inp" type="password" id="adm-pw" placeholder="Enter admin password" onkeydown="if(event.key==='Enter')login()">
    <button class="login-btn" onclick="login()">Unlock ✨</button>
    <p class="login-err" id="login-err"></p>
    <p class="login-domain">wishwall.xyz · admin@wallwishes.xyz</p>
  </div>
</div>

<!-- ADMIN PANEL -->
<div class="admin-wrap" id="adm-wrap">

  <div class="adm-header">
    <div>
      <span class="adm-logo">🧱 Wish Wall Admin</span>
      <span class="adm-domain"> · wishwall.xyz</span>
    </div>
    <button class="adm-logout" onclick="logout()">Log out</button>
  </div>

  <div class="adm-body">

    <!-- Stats -->
    <div class="adm-stats">
      <div class="adm-stat"><span class="adm-stat-num" id="a-total">0</span><span class="adm-stat-lbl">Total Wishes</span></div>
      <div class="adm-stat"><span class="adm-stat-num" id="a-pending">0</span><span class="adm-stat-lbl">Pending Review</span></div>
      <div class="adm-stat"><span class="adm-stat-num" id="a-approved">0</span><span class="adm-stat-lbl">Live on Wall</span></div>
      <div class="adm-stat"><span class="adm-stat-num" id="a-granted">0</span><span class="adm-stat-lbl">Granted ✅</span></div>
    </div>

    <!-- Ledger Editor -->
    <!--
      NOTE: Pot balance is intentionally NOT displayed publicly on wishwall.xyz
      per platform policy. This admin editor is for internal tracking only.
      The public Transparency Ledger shows: fees collected, donations, granted
      count, and avg cost — but NOT the current pot balance.
    -->
    <div class="led-editor">
      <h3>📊 Update Transparency Ledger</h3>
      <p>⚠️ The pot balance is NOT publicly visible on wishwall.xyz — internal tracking only. The public ledger shows fees, donations, granted count, and avg cost.</p>
      <div class="led-fields">
        <div class="led-field"><label>Wish Fees Collected (£)</label><input type="number" id="l-fees" value="300" min="0"></div>
        <div class="led-field"><label>Guardian Donations (£)</label><input type="number" id="l-don" value="14620" min="0"></div>
        <div class="led-field"><label>Wishes Granted</label><input type="number" id="l-gr" value="60" min="0"></div>
        <div class="led-field"><label>Avg Cost Per Wish (£)</label><input type="number" id="l-avg" value="45" min="0"></div>
        <div class="led-field"><label>Pot Balance (£) — Internal</label><input type="number" id="l-pot" value="9720" min="0"></div>
      </div>
      <button class="led-save" onclick="saveLedger()">💾 Save Ledger</button>
      <p class="led-note">Pot balance is stored in Firestore but never served to the public interface.</p>
    </div>

    <!-- Toolbar -->
    <div class="adm-toolbar">
      <input class="adm-search" type="text" id="adm-srch" placeholder="🔍 Search wishes, emails, names..." oninput="filterAdm()">
      <button class="adm-filter on" onclick="setAdmFilter('all',this)">All</button>
      <button class="adm-filter" onclick="setAdmFilter('pending',this)">⏳ Pending</button>
      <button class="adm-filter" onclick="setAdmFilter('approved',this)">🌟 Live</button>
      <button class="adm-filter" onclick="setAdmFilter('granted',this)">✅ Granted</button>
    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
      <table class="wish-table" id="adm-table">
        <thead>
          <tr>
            <th>Wish</th>
            <th>Wisher</th>
            <th>Email</th>
            <th>Country</th>
            <th>Date</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="adm-tbody">
          <tr><td colspan="7" style="text-align:center;padding:40px;color:rgba(255,255,255,.4);">Loading wishes...</td></tr>
        </tbody>
      </table>
    </div>

  </div>
</div>

<!-- Grant Modal -->
<div class="grant-modal" id="grant-modal">
  <div class="grant-box">
    <h3>✅😊 Mark as Granted</h3>
    <p>Record the cost to grant this wish (optional). The note will be ticked green with a smile on the wall.</p>
    <input class="grant-inp" type="number" id="grant-cost" placeholder="Cost in £ (optional)" min="0">
    <div class="grant-btns">
      <button class="grant-ok" onclick="confirmGrant()">Grant It ✨</button>
      <button class="grant-cancel" onclick="closeGrantModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- Respond Modal (cheeky stamp) -->
<div class="respond-modal" id="respond-modal">
  <div class="respond-box">
    <h3>💜 Add a Response Stamp</h3>
    <p>For cheeky, funny, or sweet wishes — stamp it with a response. This appears as a small badge on the note.</p>
    <div class="respond-presets">
      <span class="respond-preset" onclick="setResponse('😂 We love you')">😂 We love you</span>
      <span class="respond-preset" onclick="setResponse('🔥 Respect.')">🔥 Respect.</span>
      <span class="respond-preset" onclick="setResponse('💛 We see you')">💛 We see you</span>
      <span class="respond-preset" onclick="setResponse('🌪️ Absolutely not. And yet.')">🌪️ Absolutely not. And yet.</span>
      <span class="respond-preset" onclick="setResponse('✨ This is the way.')">✨ This is the way.</span>
      <span class="respond-preset" onclick="setResponse('🙏 Prayers submitted.')">🙏 Prayers submitted.</span>
      <span class="respond-preset" onclick="setResponse('👑 Iconic.')">👑 Iconic.</span>
      <span class="respond-preset" onclick="setResponse('💌 Thank you for being here.')">💌 Thank you for being here.</span>
    </div>
    <textarea class="respond-inp" id="respond-txt" placeholder="Or type a custom response..." rows="3"></textarea>
    <div class="grant-btns">
      <button class="grant-ok" style="background:var(--purple)" onclick="confirmRespond()">Stamp It 💜</button>
      <button class="grant-cancel" onclick="closeRespondModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
'use strict';

/* ============================================================
   AUTH — simple password gate
   ⚠️  For production: replace with Firebase Auth or equivalent
   Contact: admin@wallwishes.xyz
   ============================================================ */
const ADMIN_PW  = 'wishwall2025'; // ⚠️ CHANGE BEFORE DEPLOYING
const ADMIN_KEY = 'ww_admin_auth';

let allAdmWishes    = [];
let admFilter       = 'all';
let admSearch       = '';
let grantTargetId   = null;
let respondTargetId = null;

function login(){
  const pw = document.getElementById('adm-pw').value;
  if(pw === ADMIN_PW){
    sessionStorage.setItem(ADMIN_KEY, '1');
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('adm-wrap').classList.add('show');
    loadDemoIfNeeded();
  } else {
    document.getElementById('login-err').textContent = '❌ Wrong password. Try again.';
    document.getElementById('adm-pw').value = '';
  }
}

function logout(){
  sessionStorage.removeItem(ADMIN_KEY);
  location.reload();
}

if(sessionStorage.getItem(ADMIN_KEY)){
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('adm-wrap').classList.add('show');
  loadDemoIfNeeded();
}

/* ============================================================
   RENDER ADMIN TABLE
   ============================================================ */
window.renderAdmin = function(wishes){
  allAdmWishes = wishes;
  updateAdmStats();
  paintTable();
};

function updateAdmStats(){
  document.getElementById('a-total').textContent    = allAdmWishes.length;
  document.getElementById('a-pending').textContent  = allAdmWishes.filter(w=>w.status==='pending').length;
  document.getElementById('a-approved').textContent = allAdmWishes.filter(w=>w.status==='approved').length;
  document.getElementById('a-granted').textContent  = allAdmWishes.filter(w=>w.status==='granted').length;
}

function paintTable(){
  const tbody = document.getElementById('adm-tbody');
  let src = allAdmWishes;

  if(admFilter !== 'all') src = src.filter(w => w.status === admFilter);
  if(admSearch){
    const q = admSearch.toLowerCase();
    src = src.filter(w =>
      (w.wishText||'').toLowerCase().includes(q) ||
      (w.email||'').toLowerCase().includes(q) ||
      (w.name||'').toLowerCase().includes(q)
    );
  }

  if(!src.length){
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:rgba(255,255,255,.4);">No wishes found ✨</td></tr>';
    return;
  }

  tbody.innerHTML = src.map(w => {
    let dateStr = '—';
    try{
      const d = w.createdAt?.toDate ? w.createdAt.toDate() : (w.createdAt ? new Date(w.createdAt) : null);
      if(d) dateStr = d.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'2-digit'});
    }catch(_){}

    const statusCls = {pending:'s-pending',approved:'s-approved',granted:'s-granted'}[w.status] || 's-pending';

    const actions = [];
    if(w.status === 'pending')  actions.push(`<button class="act-btn btn-approve" onclick="approve('${esc(w.id)}')">✅ Approve</button>`);
    if(w.status !== 'granted')  actions.push(`<button class="act-btn btn-grant"   onclick="grantWish('${esc(w.id)}')">🎉 Grant</button>`);
    actions.push(`<button class="act-btn btn-respond" onclick="respondWish('${esc(w.id)}')">💜 Respond</button>`);
    actions.push(`<button class="act-btn btn-del"     onclick="del('${esc(w.id)}')">🗑 Delete</button>`);

    return `
<tr class="wish-row">
  <td>
    <div class="wish-txt">${esc(w.wishText)}</div>
    ${w.anonymous ? '<div class="wish-meta">🕶️ Anonymous post</div>' : ''}
    ${w.cheekyResponse ? `<div class="wish-meta">💜 Response: "${esc(w.cheekyResponse)}"</div>` : ''}
    ${w.isConnect ? '<div class="wish-meta">🤝 Connection wish</div>' : ''}
    ${w.grantCost ? `<div class="wish-meta">💷 Grant cost: £${w.grantCost}</div>` : ''}
  </td>
  <td style="font-size:13px;color:rgba(255,255,255,.7);">${esc(w.name || '—')}</td>
  <td style="font-size:12px;color:rgba(255,255,255,.5);">${esc(w.email || '—')}</td>
  <td style="font-size:12px;">${esc(w.country || '—')}</td>
  <td style="font-size:12px;color:rgba(255,255,255,.5);white-space:nowrap;">${dateStr}</td>
  <td><span class="status-pill ${statusCls}">${w.status}</span></td>
  <td style="white-space:nowrap;">${actions.join('')}</td>
</tr>`;
  }).join('');
}

function esc(s=''){
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

/* ============================================================
   FILTER & SEARCH
   ============================================================ */
function setAdmFilter(f, btn){
  admFilter = f;
  document.querySelectorAll('.adm-filter').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  paintTable();
}
function filterAdm(){
