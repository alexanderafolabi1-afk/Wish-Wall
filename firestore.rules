rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /wishes/{id} {
      allow read: if true;
      allow create: if request.resource.data.wishText is string && request.resource.data.wishText.size() <= 350;
      allow update, delete: if false;
    }
    match /meta/{id} { allow read: if true; allow write: if false; }
    match /donors/{id} { allow read: if true; allow write: if false; }
    match /subscribers/{id} { allow create: if true; allow read, update, delete: if false; }
    match /email_queue/{id} { allow read, write: if false; }
    match /guardian_gifts/{id} { allow create: if true; allow read, update, delete: if false; }
  }
}
